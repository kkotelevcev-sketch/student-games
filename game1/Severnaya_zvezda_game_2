        <button class="back-btn flex items-center gap-2 text-[var(--text-muted)] hover:text-[var(--brass)] mb-4 text-sm">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Вернуться к делу
        </button>

        <h2 class="font-display text-3xl font-bold mb-6 text-center text-[var(--blood)]">Обвинение</h2>

        <div class="grid md:grid-cols-2 gap-6">
