<!DOCTYPE html>
<html lang="ru">
<head>
<script src="https://telegram.org"></script>  
<meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Эхо последнего рейса: Тени в купе</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-night: #0a0c12;
      --bg-compartment: #141820;
      --bg-velvet: #1a1418;
      --wood: #2d1f16;
      --brass: #b8860b;
      --brass-dim: #705812;
      --snow: #d8e2ed;
      --blood: #6b1c1c;
      --text-main: #c8cdd8;
      --text-muted: #6a7285;
      --conductor: #5a7a9a;
      --actress: #9a5a6a;
      --historian: #5a9a6a;
      --businessman: #9a7a5a;
      --locked: #2a2a35;
      --shadow-glow: #4a3f6a;
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'Source Sans 3', sans-serif;
      background: var(--bg-night);
      color: var(--text-main);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .font-display { font-family: 'Cormorant Garamond', serif; }

    /* Snow */
    .snow-container {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
      overflow: hidden;
    }

    .snowflake {
      position: absolute;
      top: -10px;
      color: var(--snow);
      opacity: 0.4;
      animation: fall linear infinite;
    }

    @keyframes fall {
      0% { transform: translateY(-10px) rotate(0deg); opacity: 0; }
      10% { opacity: 0.4; }
      100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
    }

    /* Train effects */
    .train-sway { animation: sway 10s ease-in-out infinite; }
    @keyframes sway {
      0%, 100% { transform: rotate(-0.2deg) translateX(0); }
      50% { transform: rotate(0.2deg) translateX(1px); }
    }

    .flicker { animation: flicker 5s ease-in-out infinite; }
    @keyframes flicker {
      0%, 100%, 95% { opacity: 1; }
      96% { opacity: 0.7; }
      97% { opacity: 1; }
    }

    /* Panels */
    .compartment-panel {
      background: linear-gradient(180deg, var(--bg-compartment) 0%, #0c0e14 100%);
      border: 1px solid var(--wood);
      position: relative;
    }

    .compartment-panel::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--brass-dim), var(--brass), var(--brass-dim));
    }

    /* Evidence slot */
    .evidence-slot {
      background: var(--bg-velvet);
      border: 1px solid var(--wood);
      border-top: 3px solid var(--brass-dim);
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
    }

    .evidence-slot:hover {
      border-color: var(--brass);
      transform: translateY(-1px);
    }

    .evidence-slot.key-evidence { border-top-color: var(--blood); }

    /* Suspect card */
    .suspect-card {
      background: linear-gradient(145deg, var(--bg-compartment) 0%, var(--bg-night) 100%);
      border: 1px solid var(--wood);
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .suspect-card:hover {
      border-color: var(--brass);
      transform: translateY(-2px);
    }

    .suspect-avatar {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--brass-dim);
      flex-shrink: 0;
      transition: all 0.3s ease;
    }

    .suspect-avatar.conductor { border-color: var(--conductor); }
    .suspect-avatar.actress { border-color: var(--actress); }
    .suspect-avatar.historian { border-color: var(--historian); }
    .suspect-avatar.businessman { border-color: var(--businessman); }

    .suspect-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Buttons */
    .choice-btn {
      background: linear-gradient(135deg, var(--bg-compartment) 0%, rgba(20, 24, 32, 0.95) 100%);
      border: 1px solid var(--wood);
      color: var(--text-main);
      padding: 0.875rem 1.25rem;
      text-align: left;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
    }

    .choice-btn::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: var(--brass);
      transform: scaleY(0);
      transition: transform 0.3s ease;
    }

    .choice-btn:hover::before { transform: scaleY(1); }
    .choice-btn:hover { padding-left: 1.75rem; }

    .choice-btn.confession {
      border-color: var(--blood);
      background: linear-gradient(135deg, rgba(107, 28, 28, 0.3) 0%, var(--bg-compartment) 100%);
    }
    
    .choice-btn:disabled, .choice-btn.locked {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    .action-btn {
      background: transparent;
      border: 1px solid var(--wood);
      color: var(--text-muted);
      font-size: 0.7rem;
      padding: 0.25rem 0.5rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .action-btn:hover {
        border-color: var(--brass);
        color: var(--brass);
    }

    /* Shadow Profile */
    .shadow-level-bar {
      height: 4px;
      background: var(--wood);
      border-radius: 2px;
      overflow: hidden;
    }

    .shadow-level-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--shadow-glow), #7a6faa);
      transition: width 0.5s ease;
      box-shadow: 0 0 10px var(--shadow-glow);
    }

    /* Pulse indicator */
    .pulse-ring {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      border: 1px solid var(--blood);
      position: relative;
      margin-right: 0.5rem;
    }
    
    .pulse-ring::after {
      content: '';
      position: absolute;
      inset: 2px;
      background: var(--blood);
      border-radius: 50%;
      animation: pulse-beat 1s infinite;
      opacity: 0.8;
    }
    
    @keyframes pulse-beat {
      0%, 100% { transform: scale(1); opacity: 0.8; }
      50% { transform: scale(1.2); opacity: 0.4; }
    }
    
    .pulse-value {
      font-family: monospace;
      color: var(--text-muted);
      font-size: 0.75rem;
    }

    /* Modals */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(4px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .modal-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .modal-content {
      background: linear-gradient(180deg, var(--bg-compartment) 0%, var(--bg-night) 100%);
      border: 1px solid var(--brass);
      max-width: 500px;
      width: 90%;
      padding: 0;
      position: relative;
      transform: scale(0.9);
      transition: transform 0.3s ease;
      box-shadow: 0 0 40px rgba(184, 134, 11, 0.2);
      overflow: hidden;
    }

    .modal-overlay.active .modal-content {
      transform: scale(1);
    }

    .modal-header {
      background: linear-gradient(90deg, var(--wood), #3d2f26, var(--wood));
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--brass-dim);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-body {
      padding: 1.5rem;
      max-height: 60vh;
      overflow-y: auto;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      transition: color 0.2s;
    }
    .modal-close:hover { color: var(--brass); }

    /* Animations */
    .scene-transition { animation: fadeSlide 0.5s ease forwards; }
    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg-night); }
    ::-webkit-scrollbar-thumb { background: var(--wood); border-radius: 2px; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body class="relative train-sway">
  <div class="snow-container" id="snow-container"></div>

  <!-- Generic Modal -->
