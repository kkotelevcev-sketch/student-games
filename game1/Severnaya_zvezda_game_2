              </div>
            </div>
            <div class="flex items-center">
              <div class="pulse-ring"></div>
              <span class="pulse-value" id="pulse-value">72 BPM</span>
            </div>
          </div>
        </div>

        <div class="compartment-panel p-5 mb-4 min-h-[100px]">
          <p id="dialogue-text" class="leading-relaxed text-lg"></p>
        </div>

        <div id="choices-container" class="space-y-2"></div>
      </section>

      <!-- ACCUSATION SCREEN -->
