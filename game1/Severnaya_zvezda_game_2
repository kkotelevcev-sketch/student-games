        if (state.evidence.length === 0) {
          el.evidenceList.innerHTML = '<p class="text-xs text-[var(--text-muted)] italic">Пока пусто...</p>';
        } else {
          el.evidenceList.innerHTML = state.evidence.map(id => {
            const ev = evidenceTypes[id];
            if (!ev) return '';
            return `<div class="evidence-slot ${ev.key ? 'key-evidence' : ''} p-2 text-xs">${ev.text}</div>`;
          }).join('');
        }
      }

      // Notes List
      if (el.notesList) {
        if (state.notesFound.length === 0) {
          el.notesList.innerHTML = '<p class="text-xs text-[var(--text-muted)] italic">Пока пусто...</p>';
        } else {
          el.notesList.innerHTML = state.notesFound.map(id => {
            const note = notes[id];
            return `<div class="evidence-slot p-2 text-xs">${note.title}</div>`;
          }).join('');
        }
      }

      // Enable Accusation if interviewed at least 1 person
      const btn = document.getElementById('accusation-btn');
      if (btn) {
        if (state.interviewed.size >= 1) {
          btn.disabled = false;
          btn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    }

    function showScreen(screenId) {
      ['intro', 'hub', 'dialogue', 'accusation', 'result'].forEach(id => {
        if (el[id]) el[id].classList.add('hidden');
      });
      if (el[screenId]) {
        el[screenId].classList.remove('hidden');
        el[screenId].classList.add('scene-transition');
      }
    }

    // ==================== 5. MODAL SYSTEM ====================

    function openModal(title, content) {
      el.modalTitle.textContent = title;
      el.modalContent.innerHTML = content;
      el.genericModal.classList.add('active');
    }

    function closeModal() {
      el.genericModal.classList.remove('active');
    }

    // ==================== 6. SEARCH MECHANIC ====================

    function openSearchModal(areaId, type) {
      const areas = type === 'crime' ? crimeSceneAreas : wardAreas;
      const searchedSet = type === 'crime' ? state.searchedCrime : state.searchedWards;
      
      const area = areas.find(a => a.id === areaId);
      if (!area || searchedSet.has(areaId)) return;

      // Dynamic Loot Logic
      let lootIds = [];
      let flavorText = area.searchDesc;
      
      if (type === 'crime') {
        if (areaId === 'body') lootIds = ['blood_stain'];
        if (areaId === 'safe') lootIds = ['empty_safe'];
        if (areaId === 'window') lootIds = ['broken_window'];
        if (areaId === 'desk') lootIds = ['debt_paper'];
      } else {
        if (areaId === 'coat_check') {
            lootIds = ['stolen_coins'];
            flavorText += ' В глубине кармана одного из пальто вы находите тяжелый мешочек с монетами!';
        }
      }

      let content = `<p class="text-[var(--text-muted)] mb-4">${flavorText}</p>`;
      
      if (lootIds.length > 0) {
        const lootsHtml = lootIds.map(id => {
          const ev = evidenceTypes[id];
          return `<div class="text-xs text-[var(--brass)]">Найдено: ${ev.text}</div>`;
        }).join('');
        content += `<div class="bg-[var(--bg-night)] p-3 mb-4">${lootsHtml}</div>`;
        content += `<button class="choice-btn w-full text-center" onclick="collectLoot(['${lootIds.join("','")}'], '${areaId}', '${type}')">Забрать улики</button>`;
      } else {
        content += `<p class="text-xs text-[var(--text-muted)] italic">Ничего не найдено.</p>`;
        content += `<button class="choice-btn w-full text-center mt-4" onclick="finishSearch('${areaId}', '${type}')">Закрыть</button>`;
      }

      openModal(area.name, content);
    }

    function collectLoot(ids, areaId, type) {
      ids.forEach(id => {
        if (!state.evidence.includes(id)) state.evidence.push(id);
      });
      finishSearch(areaId, type);
    }

    function finishSearch(areaId, type) {
      const searchedSet = type === 'crime' ? state.searchedCrime : state.searchedWards;
      searchedSet.add(areaId);
      closeModal();
      updateUI();
    }

    function searchCompartment(suspectId) {
      if (state.searchedCompartments.has(suspectId)) return;
      
      const note = notes[suspectId];
      const suspect = suspects.find(s => s.id === suspectId);

      let content = `<p class="mb-4 text-[var(--text-muted)]">${suspect.compartmentDesc}</p>`;
      
      if (note) {
        content += `<div class="bg-[var(--bg-velvet)] border border-[var(--brass)] p-3 mb-4">
          <h4 class="font-display text-[var(--brass)] mb-1">${note.title}</h4>
          <p class="text-xs italic">${note.text}</p>
        </div>`;
        content += `<button class="choice-btn w-full text-center" onclick="takeNote('${suspectId}')">Изучить (+${note.shadowPoints} Проницательности)</button>`;
      } else {
        content += `<p class="text-xs text-[var(--text-muted)]">Вы перерыли всё, но ничего важного не нашли.</p>`;
        content += `<button class="choice-btn w-full text-center mt-4" onclick="closeModal()">Уйти</button>`;
      }

      openModal("Личный обыск: " + suspect.name, content);
    }

    function takeNote(suspectId) {
      const note = notes[suspectId];
      if (!state.notesFound.includes(suspectId)) {
        state.notesFound.push(suspectId);
        state.shadowLevel += note.shadowPoints;
        if (!state.evidence.includes(note.gives)) {
          state.evidence.push(note.gives);
        }
      }
      state.searchedCompartments.add(suspectId);
      closeModal();
      updateUI();
      renderHub(); // Update buttons state
    }

    // ==================== 7. DIALOGUE ENGINE ====================

    function startDialogue(suspectId) {
      state.currentWitness = suspectId;
      state.dialogueNode = 'start';
      
      const suspect = suspects.find(s => s.id === suspectId);
      if (!suspect) return;

      el.witnessName.textContent = suspect.name;
      el.witnessRole.textContent = suspect.role;
      el.witnessAvatar.className = `suspect-avatar ${suspect.color}`;
      el.witnessAvatar.innerHTML = `<img src="${suspect.image}" alt="${suspect.name}">`;
      
      state.interviewed.add(suspectId);
      
      showScreen('dialogue');
      renderDialogueNode();
    }

    function checkCondition(choice) {
      if (choice.requiresShadow && state.shadowLevel < choice.requiresShadow) return false;
      if (choice.requiresEvidence && !state.evidence.includes(choice.requiresEvidence)) return false;
      if (choice.requiresInterviewed && !state.interviewed.has(choice.requiresInterviewed)) return false;
      if (choice.requiresNote && !state.notesFound.includes(choice.requiresNote)) return false;
      return true;
    }

    function renderDialogueNode() {
      const witnessDialogues = dialogues[state.currentWitness];
      if (!witnessDialogues) return;

      const node = witnessDialogues[state.dialogueNode];
      if (!node) return;

      el.dialogueText.textContent = node.text;
      el.pulseValue.textContent = node.pulse + " BPM";
      
      if (node.pulse > 100) el.pulseValue.style.color = 'var(--blood)';
      else el.pulseValue.style.color = 'var(--text-muted)';

      el.choicesContainer.innerHTML = '';
      node.choices.forEach(choice => {
        const isUnlocked = checkCondition(choice);
        const btn = document.createElement('button');
        
        if (isUnlocked) {
          btn.className = `choice-btn w-full ${choice.addEvidence && evidenceTypes[choice.addEvidence]?.isConfession ? 'confession' : ''}`;
          btn.innerHTML = `<span>${choice.text}</span>`;
          btn.onclick = () => handleChoice(choice);
        } else {
          btn.className = "choice-btn w-full locked";
          btn.innerHTML = `<span class="text-[var(--text-muted)]">Недостаточно данных</span>`;
          btn.disabled = true;
        }
        el.choicesContainer.appendChild(btn);
      });
    }

    function handleChoice(choice) {
      if (choice.addEvidence && !state.evidence.includes(choice.addEvidence)) {
        state.evidence.push(choice.addEvidence);
        updateUI();
      }

      if (choice.forceEnd) {
        endDialogue();
        return;
      }

      if (choice.next) {
        state.dialogueNode = choice.next;
        renderDialogueNode();
      } else {
        endDialogue();
      }
    }

    function endDialogue() {
      state.currentWitness = null;
      updateUI();
      renderHub(); // Refresh UI states
      showScreen('hub');
    }

    // ==================== 8. ACCUSATION & RESULT ====================

    function showAccusationScreen() {
      state.selectedSuspect = null;
      state.selectedEvidence = null;

      const suspectCont = document.getElementById('accusation-suspects');
      suspectCont.innerHTML = suspects.map(s => `
        <button class="suspect-card p-2 w-full flex items-center gap-2" data-id="${s.id}" onclick="selectSuspect('${s.id}')">
          <div class="suspect-avatar ${s.color}" style="width:30px;height:30px"><img src="${s.image}"></div>
          <span class="text-sm">${s.name}</span>
        </button>
      `).join('');

      const evCont = document.getElementById('accusation-evidence');
      evCont.innerHTML = state.evidence.map(id => {
        const ev = evidenceTypes[id];
        if (!ev) return '';
        return `<button class="evidence-slot p-2 w-full text-left text-xs" data-id="${id}" onclick="selectEvidence('${id}')">${ev.text}</button>`;
      }).join('');

      showScreen('accusation');
    }

    function selectSuspect(id) {
      state.selectedSuspect = id;
      document.querySelectorAll('#accusation-suspects button').forEach(b => b.classList.remove('border-[var(--blood)]'));
      document.querySelector(`#accusation-suspects [data-id="${id}"]`).classList.add('border-[var(--blood)]');
      checkAccusationReady();
    }

    function selectEvidence(id) {
      state.selectedEvidence = id;
      document.querySelectorAll('#accusation-evidence button').forEach(b => b.classList.remove('border-[var(--blood)]'));
      document.querySelector(`#accusation-evidence [data-id="${id}"]`).classList.add('border-[var(--blood)]');
      checkAccusationReady();
    }

    function checkAccusationReady() {
      const btn = document.getElementById('confirm-accusation');
      if (state.selectedSuspect && state.selectedEvidence) {
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
    }

    function showResult() {
      const realKiller = 'historian';
      const success = state.selectedSuspect === realKiller;
      
      let rating, title, ratingClass;
      const ev = evidenceTypes[state.selectedEvidence];
      
      if (success && ev.isConfession) {
        rating = "S"; title = "Шерлок Холмс"; ratingClass = "rating-s";
      } else if (success && ev.key) {
        rating = "A"; title = "Инспектор"; ratingClass = "rating-a";
      } else if (success) {
        rating = "B"; title = "Стажёр"; ratingClass = "rating-b";
      } else {
        rating = "F"; title = "Провал"; ratingClass = "rating-f";
      }

      const fates = generateFates(success, state.selectedSuspect);

      const resultRating = document.getElementById('result-rating');
      resultRating.textContent = rating;
      resultRating.className = `font-display text-6xl font-bold mb-2 ${ratingClass}`;
      
      document.getElementById('result-title').textContent = title;
      
      const fatesCont = document.getElementById('fates-container');
      fatesCont.innerHTML = fates.map(f => `
        <div class="flex justify-between items-center border-b border-[var(--wood)] pb-2">
          <span class="font-bold">${f.name}</span>
          <span class="text-sm ${f.status === 'Арестован' ? 'text-[var(--blood)]' : 'text-[var(--historian)]'}">${f.status}</span>
        </div>
        <p class="text-xs text-[var(--text-muted)] mb-3">${f.text}</p>
      `).join('');

      showScreen('result');
    }

    function generateFates(success, selectedSuspect) {
      const baseFates = suspects.map(s => {
        let status = "Свободен";
        let text = "Продолжает своё дело.";
        
        if (s.id === 'historian') {
          status = success ? "Арестован" : "Скрывается";
          text = success ? "Признался и получил срок. Его книгу наконец опубликовали под его именем." : "Совесть и снег поглотили его.";
        } else if (s.id === selectedSuspect && !success) {
          status = "Ошибка правосудия";
          text = "Невиновный пострадал. Настоящий убийца избежал наказания.";
        } else if (s.id === 'businessman') {
            status = state.evidence.includes('stolen_coins') ? "Арестован за кражу" : "Банкрот";
            text = state.evidence.includes('stolen_coins') ? "Монеты найдены, джентльмен в наручниках." : "Долги поглотили его империю.";
        } else if (s.id === 'actress') {
            text = "Втайне рада исчезновению шантажиста.";
        } else if (s.id === 'conductor') {
            text = "Продолжает служить на железной дороге, но долг его тяготит.";
        }

        return { name: s.name, status, text };
      });
      return baseFates;
    }

    function restart() {
      state = {
        interviewed: new Set(),
        searchedCrime: new Set(),
        searchedWards: new Set(),
        searchedCompartments: new Set(),
        evidence: [],
        notesFound: [],
        shadowLevel: 0,
        currentWitness: null,
        dialogueNode: 'start',
        selectedSuspect: null,
        selectedEvidence: null
      };
      updateUI();
      showScreen('intro');
    }

    // ==================== 9. INITIALIZATION ====================

    function initEvents() {
      document.getElementById('start-btn').onclick = () => {
        showScreen('hub');
        renderHub();
      };

      document.querySelectorAll('.location-btn').forEach(btn => {
        btn.onclick = () => {
          const loc = btn.dataset.location;
          if (loc === 'crime') renderSearchScreen(crimeSceneAreas, 'crime');
          if (loc === 'wards') renderSearchScreen(wardAreas, 'wards');
        };
      });

      document.getElementById('accusation-btn').onclick = showAccusationScreen;
      document.getElementById('confirm-accusation').onclick = showResult;
      
      document.getElementById('restart-btn').onclick = restart;

      document.querySelectorAll('.back-btn').forEach(btn => {
        btn.onclick = () => {
          state.currentWitness = null;
          showScreen('hub');
          renderHub();
        };
      });
    }

    function renderHub() {
      el.suspectsGrid.innerHTML = suspects.map(s => {
        const interviewed = state.interviewed.has(s.id);
        const searched = state.searchedCompartments.has(s.id);
        return `
          <div class="suspect-card p-3 mb-2">
            <div class="flex items-center gap-3 mb-2" onclick="startDialogue('${s.id}')">
              <div class="suspect-avatar ${s.color}"><img src="${s.image}"></div>
              <div>
                <h3 class="font-display font-bold">${s.name}</h3>
                <p class="text-xs text-[var(--text-muted)]">${interviewed ? 'Опрошен' : 'Не опрошен'}</p>
              </div>
            </div>
            <div class="flex justify-end mt-1 border-t border-[var(--wood)] pt-2">
               <button class="action-btn ${searched ? 'opacity-50' : ''}" onclick="event.stopPropagation(); searchCompartment('${s.id}')" ${searched ? 'disabled' : ''}>
                 ${searched ? 'Обыскано' : 'Обыскать купе'}
               </button>
            </div>
          </div>
        `;
      }).join('');
      
      updateUI();
    }

    function renderSearchScreen(areas, type) {
      let content = `<div class="grid grid-cols-2 gap-3">`;
      areas.forEach(area => {
        const searchedSet = type === 'crime' ? state.searchedCrime : state.searchedWards;
        const isSearched = searchedSet.has(area.id);
        
        content += `
          <div class="p-3 border ${isSearched ? 'opacity-50 border-[var(--brass-dim)]' : 'border-[var(--wood)] hover:border-[var(--brass)] cursor-pointer'}" 
               onclick="openSearchModal('${area.id}', '${type}')">
            <h4 class="font-display text-sm">${area.name}</h4>
            <p class="text-xs text-[var(--text-muted)]">${isSearched ? 'Осмотрено' : 'Осмотреть'}</p>
          </div>
        `;
      });
      content += `</div>`;
      
      const title = type === 'crime' ? 'Купе жертвы' : 'Вагон-ресторан';
      openModal(title, content);
    }

    document.addEventListener('DOMContentLoaded', () => {
      initDOM();
      initSnow();
      initEvents();
      updateUI();
    });
  </script>
</body>
</html>
